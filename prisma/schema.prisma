generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(cuid())
  clerkId      String        @unique
  email        String        @unique
  name         String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  credits      Int           @default(3)
  isPro        Boolean       @default(false)
  proExpiresAt DateTime?
  referralCode String?       @unique
  referredBy   String?
  cv           CV?
  applications Application[]
  savedJobs    SavedJob[]
  payments     Payment[]
}

model CV {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String?
  email           String?
  phone           String?
  location        String?
  title           String?
  summary         String?
  skills          String[]
  experienceYears Int?
  education       String?
  languages       String[]
  experience      Json?
  atsScore        Int?
  rawText         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Application {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobTitle    String
  company     String
  location    String?
  jobUrl      String?
  jobSource   String?
  status      String   @default("Applied")
  cvVersion   String?
  matchScore  Int?
  appliedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SavedJob {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobTitle  String
  company   String
  location  String?
  jobUrl    String
  jobData   Json?
  savedAt   DateTime @default(now())
}

model Payment {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reference   String   @unique
  amount      Int
  currency    String   @default("ZAR")
  plan        String
  status      String   @default("pending")
  paystackRef String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ReferralTracking {
  id          String   @id @default(cuid())
  referrerId  String
  referredId  String
  createdAt   DateTime @default(now())
}
